{
  "$schema": "https://raw.githubusercontent.com/nicegui/tauri-v2/refs/heads/dev/crates/tauri-config-schema/schema.json",
  "productName": "ImgBed",
  "version": "0.1.0",
  "identifier": "com.imgbed.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "ImgBed",
        "width": 360,
        "height": 480,
        "resizable": true,
        "closable": true,
        "minimizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
